# Ansible Managed: {{ server.domain }}
# Path: /etc/nginx/conf.d/{{ server.domain }}.conf

# HTTP -> HTTPS Redirect
server {
    listen 80;
    server_name {{ server.domain }};
    return 301 https://$host$request_uri;
}

# HTTPS Proxy
server {
    listen 443 ssl http2;
    server_name {{ server.domain }};

    # SSL Config
    ssl_certificate /etc/nginx/ssl/{{ ingress_root_domain }}/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/{{ ingress_root_domain }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305;

    access_log /var/log/nginx/{{ server.domain }}_access.log;
    error_log /var/log/nginx/{{ server.domain }}_error.log;

    location / {
        proxy_pass {{ server.upstream }};

{% if server.force_ip_header | default(false) %}
        proxy_set_header Host $proxy_host;
        proxy_set_header Origin {{ server.upstream }};
        proxy_set_header Referer {{ server.upstream }};
{% else %}
        proxy_set_header Host $host;
{% endif %}
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
{% if server.websocket | default(false) %}
        # WebSocket Support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
{% endif %}
    }
}
