services:
  uptime-kuma:
    image: louislam/uptime-kuma:{{ monitoring_uptime_kuma_version }}
    container_name: uptime-kuma
    restart: unless-stopped
    ports:
      - "{{ monitoring_uptime_kuma_port }}:3001"
    volumes:
      - /opt/monitoring/uptime-kuma:/app/data

  netdata:
    image: netdata/netdata:{{ monitoring_netdata_version }}
    container_name: netdata
    hostname: {{ inventory_hostname }}
    restart: unless-stopped
    ports:
      - "{{ monitoring_netdata_port }}:19999"
    cap_add:
      - SYS_PTRACE
      - SYS_ADMIN
    security_opt:
      - apparmor:unconfined
    volumes:
      - /opt/monitoring/netdata/config:/etc/netdata
      - /opt/monitoring/netdata/lib:/var/lib/netdata
      - /opt/monitoring/netdata/cache:/var/cache/netdata
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /etc/passwd:/host/etc/passwd:ro
      - /etc/group:/host/etc/group:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
