services:
  app:
    image: ghcr.io/masudur-rahman/expense-tracker-bot:{{ expense_bot_version }}
    container_name: expense-tracker
    command: serve
    restart: unless-stopped

    environment:
      - TELEGRAM_BOT_TOKEN={{ expense_bot_token }}
      - OPENROUTER_API_KEY={{ expense_bot_openrouter_key }}

    volumes:
      - ./config.yaml:/configs/.expense-tracker.yaml
      - ./app_data:/.expense-tracker
