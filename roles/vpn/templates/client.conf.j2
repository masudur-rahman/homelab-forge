[Interface]
PrivateKey = {{ lookup('file', vpn_wireguard_key_path + '/' + client.name + '.key') }}
Address = {{ client.ip }}/32
DNS = 1.1.1.1

[Peer]
PublicKey = {{ lookup('file', vpn_wireguard_key_path + '/server.pub') }}
Endpoint = {{ vpn_wireguard_endpoint | default(vpn_wireguard_ha_vip) | default(ansible_host) }}:{{ vpn_wireguard_port }}
AllowedIPs = 0.0.0.0/0, ::/0
PersistentKeepalive = 25
